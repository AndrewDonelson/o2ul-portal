# ─────────────────────────────────────────────────────────────────────────────
# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Full connection string for the Postgres 16 database.
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
POSTGRES_DSN=postgres://template_user:CHANGE_ME@localhost:5432/template_db?sslmode=disable

# ─────────────────────────────────────────────────────────────────────────────
# ─── Redis ────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Address of the Redis 7 instance used by Strata L2 cache.
REDIS_ADDR=localhost:6379

# ─────────────────────────────────────────────────────────────────────────────
# ─── Auth ─────────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=replace-me

# Master Admin bootstrap
MASTER_ADMIN_USERNAME=
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=

# ─── Runtime ──────────────────────────────────────────────────────────────────
# Application environment mode (development, staging, production).
APP_ENV=development

# Server email support (proton Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=


# ─────────────────────────────────────────────────────────────────────────────
# ─── Orchestrator ─────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# HTTP listen address and backend adapter mode for orchestrator service.
# ORCHESTRATOR_BACKEND options: local, systemd, docker, kubernetes
ORCHESTRATOR_ADDR=:8090
ORCHESTRATOR_BACKEND=local

# Shared control token for internal orchestrator-protected endpoints.
ORCHESTRATOR_CONTROL_TOKEN=replace-with-strong-token

# Optional forwarding sink for API runtime logs.
ORCHESTRATOR_LOG_URL=http://localhost:8090/api/v1/logs/ingest

# ─────────────────────────────────────────────────────────────────────────────
# ─── API Server ───────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# HTTP listen address for the API service.
APP_ADDR=:8080

# ─────────────────────────────────────────────────────────────────────────────
# ─── WEB Server ───────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# HTTP listen address and static asset root for internal web server.
WEB_ADDR=:8081
WEB_ROOT_DIR=./web/dist-app

# Enable HTTP/3 (QUIC) and provide TLS certificate/key paths when enabled.
WEB_ENABLE_HTTP3=true
WEB_TLS_CERT_FILE=
WEB_TLS_KEY_FILE=

# Startup image optimization for static assets served by WEB.
# Modes: off | changed | all
WEB_IMAGE_OPTIMIZATION_ENABLED=true
WEB_IMAGE_OPTIMIZATION_MODE=changed
WEB_IMAGE_OPTIMIZATION_MANIFEST=.imageopt-manifest.json
WEB_IMAGE_OPTIMIZATION_TIMEOUT_SECONDS=20

# ─────────────────────────────────────────────────────────────────────────────
# ─── Shutdown Policy ──────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Global service shutdown timeout and per-phase timeout in seconds.
SHUTDOWN_TIMEOUT_SECONDS=30
SHUTDOWN_PHASE_TIMEOUT_SECONDS=10

# Internal shutdown endpoints used by orchestrator-managed lifecycle.
MANAGED_API_SHUTDOWN_URL=http://localhost:8080/internal/shutdown
MANAGED_SERVER_SHUTDOWN_URL=http://localhost:8081/internal/shutdown

# ─────────────────────────────────────────────────────────────────────────────
# ─── Managed Startup ──────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Controls orchestrator-managed startup sequencing for API and WEB services.
MANAGED_STARTUP_ENABLED=true
MANAGED_STARTUP_TIMEOUT_SECONDS=45

# API process configuration used by orchestrator during managed startup.
MANAGED_API_SERVICE=api
MANAGED_API_COMMAND=go
MANAGED_API_ARGS=run ./cmd/api
MANAGED_API_HEALTH_URL=http://localhost:8080/health

# WEB process configuration used by orchestrator during managed startup.
MANAGED_WEB_SERVICE=web
MANAGED_WEB_COMMAND=go
MANAGED_WEB_ARGS=run ./cmd/web
MANAGED_WEB_HEALTH_URL=http://localhost:8081/healthz

# ─────────────────────────────────────────────────────────────────────────────
# ─── Payments ────────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# Stripe API keys for payment processing. Obtain these from your Stripe dashboard.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Steam publisher key and app ID for Steam integration. Obtain these from your Steamworks dashboard.
STEAM_WEB_API_KEY=
STEAM_PUBLISHER_KEY=
STEAM_USERNAME=
STEAM_LOGIN_PWD=
STEAM_APP_ID=
STEAM_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# ─── Deployment ─────────────────────────────────────────────────────────────
# ─────────────────────────────────────────────────────────────────────────────
# GitHub Actions deploy secrets source-of-truth (copy into repo secrets)
# Sombrero (primary production VPS)
DEPLOY_HOST=
# Andromeda (secondary production VPS)
ANDROMEDA_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY=
DEPLOY_SSH_KNOWN_HOSTS=
# Default manual deploy target for workflow_dispatch (sombrero|andromeda)
DEPLOY_TARGET=sombrero

# Optional NGINX one-time setup overrides (server)
NGINX_PROJECT_SLUG=com-nlaak-backend-template
NGINX_SERVER_NAME=_
NGINX_LISTEN_PORT=80
NGINX_CONF_NAME=com-nlaak-backend-template.conf
